{
  "name": "convo-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:widget && next build",
    "start": "next start",
    "lint": "eslint && npm run lint:migrations",
    "lint:migrations": "node scripts/lint-migrations.mjs",
    "build:widget": "node scripts/build-widget.mjs",
    "validate:config": "tsx scripts/validate-forum-config.ts",
    "migrate": "node scripts/migrate.mjs",
    "migrate:dry-run": "MIGRATE_DRY_RUN=1 node scripts/migrate.mjs",
    "migrate:baseline": "node scripts/baseline-migrations.mjs",
    "migrate:journal": "node scripts/build-journal.mjs",
    "migrate:check": "node scripts/check-migrations.mjs",
    "test:migrations": "node scripts/__tests__/baseline-migrations.test.mjs",
    "test:canary": "tsx src/app/api/cron/migration-drift-canary/__tests__/handler.test.ts",
    "test": "tsx --test \"src/**/*.test.ts\" \"scripts/**/*.test.ts\" \"__tests__/**/*.test.ts\" \"docs/**/*.test.ts\""
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@neondatabase/serverless": "^1.0.2",
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/typography": "^0.5.19",
    "argon2": "^0.44.0",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.0",
    "next": "16.2.3",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.13",
    "openai": "^6.34.0",
    "otplib": "^13.4.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/marked": "^5.0.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "clean-css": "^5.3.3",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
