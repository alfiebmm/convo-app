# Database (Neon / Supabase Postgres)
DATABASE_URL=postgresql://user:password@host:5432/convo
NEXT_PUBLIC_SUPABASE_URL=https://project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# OpenAI (Phase 2)
OPENAI_API_KEY=sk-...

# Auth (NextAuth v5)
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (for magic links)
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=user
EMAIL_SERVER_PASSWORD=password
EMAIL_FROM=noreply@convo.app

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_SCALE=price_...

# Platform admin
# Comma-separated email allowlist for /platform-admin/*.
# Must match users.email, and users.is_platform_staff must also be true.
PLATFORM_STAFF_EMAILS=founder@example.com
